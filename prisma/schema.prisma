generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Flow {
  id        Int      @id @default(autoincrement())
  name      String
  trigger   String
  action    String
  createdAt DateTime @default(now())
}

model Log {
  id        Int      @id @default(autoincrement())
  message   String
  createdAt DateTime @default(now())
}
